# Target environment — defaults to https://vault.bitwarden.com if not set
# WEB_APP_URL=https://vault.bitwarden.com       # production
# WEB_APP_URL=https://vault.qa.bitwarden.pw     # QA
WEB_APP_URL=

# Your Bitwarden organization GUID
# Find this in the URL when navigating to your organization in the web vault
# e.g. https://vault.bitwarden.com/#/organizations/<ORG_ID>/...
ORG_ID=

# Contentful — required for the upload pipeline (Phase 2)
# CONTENTFUL_SPACE_ID=
# CONTENTFUL_ENVIRONMENT=master
# CONTENTFUL_MANAGEMENT_TOKEN=
