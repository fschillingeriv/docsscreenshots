{
  "name": "docs-screenshots",
  "version": "1.0.0",
  "description": "Automated screenshot pipeline for Bitwarden documentation",
  "type": "module",
  "scripts": {
    "screenshot": "playwright test 2>&1 | tee last-run.log",
    "screenshot:web": "playwright test --project=web 2>&1 | tee last-run.log",
    "screenshot:passwordmanager": "playwright test --project=passwordmanager 2>&1 | tee last-run.log"
  },
  "devDependencies": {
    "@playwright/test": "^1.43.0"
  },
  "dependencies": {
    "dotenv": "^16.4.5"
  }
}
